# ---- Backend configuration ----
# SQLAlchemy database URL. Defaults to a SQLite file in /database.
DATABASE_URL=sqlite:///./database/banking_alerts.db

# Transaction simulator
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_SECONDS=4

# ---- Email notifications (optional) ----
# When SMTP is not configured, "email" notifications are written to the
# system log instead of being sent, so the app still works out of the box.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@bank.local
ALERT_EMAIL_TO=ops-team@bank.local

# ---- Admin ----
# Simple shared secret used to authorise admin/config actions.
# Sent by the frontend as the "X-Admin-Token" header.
ADMIN_TOKEN=admin-secret-token
